.vscode/

# Node dependencies
node_modules

# Local env files
.env
.env.*
!.env.example

# Build outputs
dist/

# Ban logs
logs/
scripts/shell/pull-data.sh
scripts/shell/deploy.sh

# Data files
data/chat-registry.json

# Source files
references/result.json

# Gitignore all docs by default
docs/*

# Whitelist: explicitly tracked documentation
!docs/README.md
!docs/architecture/
!docs/configuration/
!docs/services/
!docs/validators/

# Keep deploy.md ignored (private deployment notes)
docs/deployment/deploy.md